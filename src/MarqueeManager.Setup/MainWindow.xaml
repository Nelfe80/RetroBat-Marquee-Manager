<Window x:Class="MarqueeManager.Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Marquee Manager Setup"
        Width="1200" Height="720"
        MinWidth="1000" MinHeight="600"
        Background="{DynamicResource AppBackground}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ======================= sidebar ======================= -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="14,18,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- brand -->
                <Grid Margin="8,0,2,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="BrandIconHost" Width="36" Height="36" CornerRadius="9"
                            Margin="0,0,10,0" VerticalAlignment="Center"
                            Background="{DynamicResource ControlBackground}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Marquee Manager" Foreground="{DynamicResource AppForeground}"
                                   FontSize="13" FontWeight="Bold"/>
                        <TextBlock Text="SETUP STUDIO" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGradient}" Margin="1,1,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0,0,0">
                        <Button x:Name="ThemeToggle" Width="28" Height="28" Padding="0"
                                FontFamily="Segoe MDL2 Assets" FontSize="12" Content="&#xE706;"
                                Click="ThemeToggle_Click"/>
                        <Button x:Name="LangToggle" Width="28" Height="22" Padding="0"
                                FontSize="9" FontWeight="Bold" Content="EN" Margin="0,4,0,0"
                                Click="LangToggle_Click"/>
                    </StackPanel>
                </Grid>

                <!-- navigation -->
                <StackPanel Grid.Row="1" Margin="0,26,0,0">
                    <RadioButton x:Name="NavHome" Style="{StaticResource NavItem}" Tag="&#xE80F;"
                                 Content="Accueil" GroupName="nav" IsChecked="True"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavSetup" Style="{StaticResource NavItem}" Tag="&#xE7F4;"
                                 Content="Mon setup" GroupName="nav"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavSystems" Style="{StaticResource NavItem}" Tag="&#xE8F1;"
                                 Content="Mes systèmes" GroupName="nav"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavGames" Style="{StaticResource NavItem}" Tag="&#xE7FC;"
                                 Content="Mes jeux" GroupName="nav"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavOptions" Style="{StaticResource NavItem}" Tag="&#xE713;"
                                 Content="Options" GroupName="nav"
                                 Checked="Nav_Checked"/>
                    <RadioButton x:Name="NavDiagnostic" Style="{StaticResource NavItem}" Tag="&#xE90F;"
                                 Content="Diagnostic" GroupName="nav"
                                 Checked="Nav_Checked"/>
                </StackPanel>

                <!-- status card -->
                <Border Grid.Row="2" Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource HairlineBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="12,11">
                    <TextBlock x:Name="FooterInfo" Foreground="{DynamicResource AppMuted}"
                               FontSize="10" LineHeight="15" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <ContentControl x:Name="ContentHost" Grid.Column="1"/>
    </Grid>
</Window>
